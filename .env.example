# VPN configuration
# Copy this to ~/.config/af-vpn/.env and fill in your values.
# Secrets (host/username/password) stay in VPN_CONFIG — not here.

# Path to your openfortivpn config file (holds host/username/password)
VPN_CONFIG=/path/to/vpn-config

# openfortivpn binary path (leave blank to use OS default)
# macOS (Homebrew):  /opt/homebrew/bin/openfortivpn
# Linux (apt):       /usr/bin/openfortivpn
VPN_FORTIVPN_BIN=

# DNS servers pushed when tunnel comes up
VPN_DNS_PRIMARY=10.10.0.1
VPN_DNS_SECONDARY=10.10.0.2
VPN_DNS_METHOD=auto   # auto | resolvectl | resolv | networksetup
VPN_VPN_INTERFACE=ppp0

# OTP email settings
VPN_OTP_SENDER=no-reply@forti-notifications.com
VPN_OTP_TIMEOUT=30
VPN_OTP_POLL_INTERVAL=5
VPN_WAIT_BEFORE_INBOX=7

# Browser (Playwright Firefox)
VPN_BROWSER_USER_DATA_DIR=~/.vpn-otp-browser-profile
VPN_BROWSER_VISIBLE=false
